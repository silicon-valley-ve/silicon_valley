<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_vat_wh_voucher">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout" t-lang="es_VE">
                    <div class="header">
                        <style>
                                body { font-family: 'Arial', sans-serif; }
                                .header-title { font-size: 16px; font-weight: bold; text-align: center; margin-top: 10px; }
                                .sub-header { font-size: 12px; text-align: center; }
                                .info-box { border: 1px solid black; padding: 5px; margin-bottom: 10px; }
                                .info-box table { width: 100%; border-collapse: collapse; }
                                .info-box td { font-size: 10px; padding: 2px; }
                                .info-box .label { font-weight: bold; }
                                .table-header { font-weight: bold; text-align: center; background-color: #f2f2f2; }
                                .main-table { width: 100%; border-collapse: collapse; margin-top: 15px; }
                                .main-table th, .main-table td { border: 1px solid black; padding: 5px; font-size: 10px; }
                                .text-right { text-align: right; }
                                .text-center { text-align: center; }
                                .footer-note { font-size: 8px; margin-top: 20px; text-align: center; }
                        </style>

                        <div class="header-title">
                                COMPROBANTE DE RETENCIÓN DEL IMPUESTO AL VALOR AGREGADO I.V.A.
                        </div>
                        <div class="sub-header">
                            Providencia Administrativa Nº SNAT/2025/000054 de fecha 02 de julio de 2025
                        </div>
                        <div class="sub-header">
                            Decreto Constituyente de Reforma Parcial del Decreto con Rango, Valor y Fuerza de Ley que establece el Impuesto al Valor Agregado Gaceta Oficial N 6.507 Ext. del 29-01-2020
                        </div>
                        
                            <table class="main-table" style="width: 70%; margin-left: auto; margin-right: auto; border: 1px solid white;">
                                <tr>
                                    <td style="border: 1px solid white;">
                                        Artículo 11: " La Administración Tributaria podrá designar como responsables del pago del impuesto, en calidad de agentes de retención, a quienes por sus funciones públicas o por razón de sus actividades privadas intervengan en operaciones gravadas con el impuesto establecido en esta Ley.(...)"
                                    </td>
                                </tr>
                            </table>
                        

                    </div>
                    <div class="page">
                        <table style="width: 60%; margin-left: auto; margin-right: auto;">
                          <tr>
                            <td width="55%" align="center">NÚMERO DE COMPROBANTE:</td>
                            <td width="25%" align="center">
                                <span t-esc="o.retention_line_ids.retention_id.name"/>
                            </td>
                            <td width="20%" align="right">
                                <span t-field="o.retention_line_ids.retention_id.voucher_delivery_date"/>
                            </td>
                          </tr>
                        </table>

                        <style>
                            /* Estilo para los bordes de la tabla principal (gruesos y blancos) */
                            .thicker-border-table, .thicker-border-table th, .thicker-border-table td {
                                border: 8px solid white;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="inta"], table[name="inta"] th, table[name="inta"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intb"], table[name="intb"] th, table[name="intb"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intc"], table[name="intc"] th, table[name="intc"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intd"], table[name="intd"] th, table[name="intd"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intg"], table[name="intg"] th, table[name="intg"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="int_hh"], table[name="int_hh"] th, table[name="int_hh"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="inti"], table[name="inti"] th, table[name="inti"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intj"], table[name="intj"] th, table[name="intj"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                            /* Estilo para la tabla interna (delgados y negros) */
                            table[name="intz"], table[name="intz"] th, table[name="intz"] td {
                                border: 1px solid black;
                                border-collapse: collapse;
                            }

                        </style>

                        
                        <br/>
                        <!--table class="thicker-border-table" style="width: 100%;"-->
                        <table style="width: 100%; border: 1px solid white;">
                          <tr>
                            <td width="64%">
                                &amp;nbsp;
                            </td>
                            <td width="8%" rowspan="5">&amp;nbsp;</td>
                            <!--td width="28%" align="right"-->
                            <td align="center" height="60px" width="28%" style="vertical-align: middle;">
                                <table width="80%"  name="intz">
                                    <tr>
                                      <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        <div align="center"> PERÍODO DE IMPOSICIÓN. </div>
                                      </td>
                                    </tr>
                                    <tr>
                                      <td>
                                        <div align="center">
                                          <span t-esc="o.periodo()" />
                                        </div>
                                       </td>
                                      </tr>
                                </table>
                            </td>
                          </tr>
                          <tr>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="inta">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        NOMBRES Y APELLIDOS O RAZÓN SOCIAL DEL AGENTE DE RETENCIÓN:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">
                                        <span t-esc="o.company_id.name"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                            
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="intg">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        Nº REGISTRO INFORMACIÓN FISCAL (RIF) DEL AGENTE DE RETENCIÓN:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">      
                                        <span t-esc="o.company_id.vat"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                          </tr>
                          <tr>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="intb">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        DOMICILIO FISCAL DEL AGENTE DE RETENCION
                                    </td>
                                  </tr>
                                  <tr>
                                    <td>
                                        <span t-esc="o.company_id.street"/>, 
                                        <span t-esc="o.company_id.street2"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="int_hh">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        TELÉFONOS DEL AGENTE DE RETENCION:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">
                                        <span t-esc="o.company_id.partner_id.phone"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                          </tr>
                          <tr>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="intc">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        NOMBRES Y APELLIDOS O RAZÓN SOCIAL DEL PROVEEDOR:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">
                                        <span t-esc="o.partner_id.name"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="inti">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        Nº REGISTRO ÚNICO DE INFORMACIÓN FISCAL (RIF) DEL PROVEEDOR:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">
                                        <span t-esc="o.partner_id.vat"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                          </tr>
                          <tr>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="intd">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        DOMICILIO FISCAL DEL PROVEEDOR
                                    </td>
                                  </tr>
                                  <tr>
                                    <td>
                                        <span t-esc="o.partner_id.street"/>, 
                                        <span t-esc="o.partner_id.street2"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                            <td align="center" height="60px" style="vertical-align: middle;">
                                <table width="98%" name="intj">
                                  <tr>
                                    <td style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                                        TELÉFONOS DEL PROVEEDOR:
                                    </td>
                                  </tr>
                                  <tr>
                                    <td align="center">
                                        &amp;nbsp;
                                        <span t-esc="o.partner_id.phone"/>
                                    </td>
                                  </tr>
                                </table>
                            </td>
                          </tr>
                          
                          <tr>
                            <td colspan="3">&amp;nbsp;</td>
                          </tr>
                        </table>
                        

                        <table width="100%" >
                          <tr style="text-align: center; font-size:9px; background-color:#F2F2F2;">
                            <td>OPERACIÓN NÚMERO</td>
                            <td>FECHA DEL DOCUMENTO</td>
                            <td>TIPO DE DOCUMENTO 
                                FAC/ND/NC
                            </td>
                            <td>NÚMERO DE DOCUMENTO</td>
                            <td>NÚMERO DE CONTROL</td>
                            <td>
                                TIPO DE TRANSACCIÓN 01-reg, 03 anul
                            </td>
                            <td>
                                NÚMERO DE DOCUMENTO AFECTADO
                            </td>
                            <td>TOTAL COMPRAS INCLUYENDO IVA</td>
                            <td>
                                COMPRAS SIN DERECHO A CRÉDITO FISCAL
                            </td>
                            <td>BASE IMPONIBLE</td>
                            <td>ALICUOTA IVA %</td>
                            <td>IMPUESTO CAUSADO IVA</td>
                            <td>RET. %</td>
                            <td>
                                MONTO DEL IMPUESTO IVA RETENIDO
                            </td>
                          </tr>

                          <t t-set="total_base_imponible" t-value="0" />
                          <t t-set="total_iva" t-value="0" />
                          <t t-set="total_ret" t-value="0" />
                          <t t-set="num" t-value="1" />

                          <tr t-foreach="o.retention_line_ids" t-as="line" style="text-align: center; font-size:9px;">
                            <td><t t-esc="num"/></td>
                            <td><span t-esc="line.formato_fecha()"/></td>
                            <td>
                                <t t-if="o.type == 'in_invoice'">
                                    FACT
                                </t>
                                <t t-if="o.type == 'in_refund'">
                                    NC
                                </t>
                                <t t-if="o.type == 'in_receipt'">
                                    ND
                                </t>
                            </td>
                            <td><span t-esc="line.invoice_id.invoice_number_next"/></td>
                            <td><span t-esc="line.invoice_id.invoice_number_control"/></td>
                            <td>
                                <strong t-if="line.invoice_id.move_type == 'in_invoice'">01-Reg</strong>
                                <strong t-if="line.invoice_id.move_type in ('in_refund','in_receipt')">03-Anul</strong>
                            </td>
                            <td><span t-esc="line.invoice_id.fact_afect"/></td>
                            <td><span t-esc="line.float_format(abs(line.invoice_id.amount_total_signed))" /></td>
                            <td><span t-esc="line.valida_excento()"/></td>
                            <td>
                                <t t-if="line.tax_id.amount!=0"  >
                                    <!--span t-esc="line.float_format(line.invoice_id.amount_untaxed)"/ OJO -->
                                    <span t-esc="line.float_format(line.base_imponible)"/>
                                    <t t-set="total_base_imponible" t-value="total_base_imponible+line.base_imponible" />
                                </t>
                            </td>
                            <td>
                                <t t-set="por_iva" t-value="line.tax_id.amount" />
                                <t t-if="line.tax_id.amount!=0"  >
                                    <span>
                                        <p t-raw="line.float_format(por_iva)" ></p>
                                    </span>
                                </t>
                            </td>
                            <td>
                                <t t-if="line.tax_id.amount!=0"  >
                                    <span t-esc="line.float_format(line.amount_vat_ret)"/>
                                    <t t-set="total_iva" t-value="total_iva+line.amount_vat_ret" />
                                </t>
                            </td>
                            <td>
                                <t t-if="line.tax_id.amount!=0"  >
                                    <span t-esc="line.float_format(line.retention_rate)"/>
                                </t>
                            </td>
                            <td>
                                <t t-if="line.tax_id.amount!=0"  >
                                    <span t-esc="line.float_format(line.retention_amount)"/>
                                    <t t-set="total_ret" t-value="total_ret+line.retention_amount" />
                                </t>
                            </td>
                            <t t-set="num" t-value="num+1" />
                          </tr>
                          <tr style="text-align: center; font-size:10px;">
                            <td colspan="7">
                                &amp;nbsp;
                            </td>
                            <td>
                                <strong t-esc="o.float_format2(abs(o.invoice_id.amount_total_signed))" />
                            </td>
                            <td>
                                &amp;nbsp;
                            </td>
                            <td>
                                <strong t-esc="o.float_format2(total_base_imponible)"/>
                            </td>
                            <td>
                                &amp;nbsp;
                            </td>
                            <td>
                                <strong t-esc="o.float_format2(total_iva)"/>
                            </td>
                            <td>
                                &amp;nbsp;
                            </td>
                            <td>
                                <strong t-esc="o.float_format2(total_ret)"/>
                            </td>
                          </tr>
                        </table>

                        <br/>

                        <table width="100%" class="table table-borderless table-sm">
                          <tr>
                            <td width="72%">&amp;nbsp;</td>
                            <td><div align="center">
                                  <table width="100%" style="border: 3px solid black; font-size:10px;">
                                    <tr>
                                      <td><div align="center"><span>NETO A PAGAR Bs. </span></div></td>
                                      <td><div align="right"><span><span t-esc="o.float_format2(abs(o.invoice_id.amount_total_signed)-total_ret)" /></span></div></td>
                                    </tr>
                                  </table>
                                </div>
                            </td>
                          </tr>
                        </table>

                        <style>
                            hr {
                                border-color: #000;
                                width: 60%;
                                margin-left: auto;
                                margin-right: auto;
                                margin-top: 0px;
                                margin-bottom: 0px;
                            }
                        </style>

                        <div class="row">
                                <t t-if="o.type in ('in_invoice','in_refund','in_receipt')"  > 
                                <table class="table table-borderless" style="width:100%;margin-top:10px;" name="firmas">
                                <!--table style="width:100%;margin-top:50px;" name="firmas"-->
                                    <tr>
                                        <td style="width:50%;text-align:center;padding:0px;margin:0px;">
                                            <div style="position: absolute; left: 240px; top: 475px; z-index: 1;">
                                                <t t-if="o.create_uid.sign_signature"> 
                                                  <img t-attf-src="data:image/*;base64,{{o.create_uid.sign_signature}}" style="width:auto; height:100px;"/>
                                                </t>
                                            </div>
                                            <br/>
                                            <div class="row justify-content-center">
                                                <div class="border-bottom border-dark border-1" style="max-width: 450px;"/>
                                            </div>
                                            <b><span t-esc="o.create_uid.partner_id.name"/></b>
                                            <br/>
                                            <b>Agente de Retención</b>
                                            <br/>
                                            <b>Firma Sello</b>
                                        </td>
                                        <td style="width:50%;text-align:center;padding:0px;margin:0px;">
                                            <br/>
                                            <div class="row justify-content-center">
                                                <div class="border-bottom border-dark border-1" style="max-width: 450px;"/>
                                            </div>  
                                                <b><span t-esc="o.partner_id.name"/></b>
                                                <br/>
                                                 Proveedor 
                                            <br/>
                                            <b>Firma Sello</b>
                                        </td>
                                    </tr>
                                </table>
                            </t>
                            </div>

                        

                    </div>  
                    <div class="footer">
                        <div class="row justify-content-center" style="font-size:11px;">  
                            
                            Este comprobante se emite según lo establecido en el Artículo Nº 16 de la Providencia Administrativa Nº SNAT/2025/000054 de fecha 02 de julio de 2025, Publicada Gaceta Oficial N° 43.171 de fecha 16 Julio de 2025
                            
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>








<!-- Paper format -->
    <record id="paperformat_vat_retention" model="report.paperformat">
        <field name="name">VAT Retention Report</field>
        <field name="orientation">Landscape</field>
        <field name="header_line" eval="False"/>
    </record>

    <!--record id="action_iva_ret_report" model="ir.actions.report">
             <field name="paperformat_id" ref="iva_retention.paperformat_vat_retention"/>
    </record-->

    <record id="action_iva_ret_report" model="ir.actions.report">
            <field name="name">Comprobante de IVA</field>
            <field name="model">vat.retention</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">iva_retention.template_vat_wh_voucher</field>
            <field name="report_file">iva_retention.template_vat_wh_voucher</field>
            <field name="binding_model_id" eval="False"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="iva_retention.paperformat_vat_retention"/>
        </record>

