<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        

        <record id="account_inherit_view_form_fd" model="ir.ui.view">
            <field name="name">account.inherit.view.form.fd</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                  <page string="Resp Json Fact. Dig." name="studio_page_TtooT">
                    <group name="studio_group_TtooT">
                      <group name="studio_group_TtooT_left">
                        <field name="validaciones"/>
                        <field name="codigo"/>
                        <field name="mensaje"/>
                      </group>
                      <group name="studio_group_TtooT_right">
                        <field name="token"/>
                        <field name="resultado"/>
                        <field name="urlConsulta" string="URL Factura" widget="url"/>
                      </group>
                    </group>
                  </page>
                </xpath>

                <xpath expr="//button[@id='account_invoice_payment_btn']" position="after">
                         <button name="simular" string="simular" type="object" />
                         <button name="print_digital" string="Imprimir. Doc. Digital" type="object" class="btn-danger" attrs="{'invisible': ['|',('state', '!=', 'posted'),('move_type','=','entry')]}"/>
                         <!--button name="button_draft" string="borrador 2" type="object" /-->
                </xpath>


            </field>
        </record>

    </data>
</odoo>