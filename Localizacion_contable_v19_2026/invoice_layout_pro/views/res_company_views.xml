<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_ilp" model="ir.ui.view">
        <field name="name">res.company.form.ilp</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Invoice Layout Pro" name="ilp_settings">
                    <group string="Couleurs du tableau">
                        <field name="ilp_th_bg_color"    widget="color" string="Fond entêtes"/>
                        <field name="ilp_th_text_color"  widget="color" string="Texte entêtes"/>
                        <field name="ilp_title_color"    widget="color" string="Titre facture"/>
                        <field name="ilp_total_bg_color" widget="color" string="Fond total"/>
                        <field name="ilp_total_text_color" widget="color" string="Texte total"/>
                    </group>
                    <group string="Pied de page légal">
                        <field name="ilp_legal_terms" widget="html"/>
                    </group>
                    <group string="CSS avancé">
                        <field name="ilp_custom_css" widget="code"
                               options="{'mode': 'css'}"
                               placeholder="/* ex: .o_main_table { font-size: 11px; } */"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
