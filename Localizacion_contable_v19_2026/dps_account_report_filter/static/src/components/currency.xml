<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <!-- Extension Data -->
    <t t-name="dps_account_report_filter.AccountReportCurrenciesData">
        <Dropdown>
            <button class="btn btn-secondary">
                <i class="fa fa-money me-1"/><t t-out="controller.options.selected_currencies"/>
            </button>

            <t t-set-slot="content">
                <t t-foreach="controller.options.currencies" t-as="currency" t-key="currency_index">
                    
                    <DropdownItem
                        class="{ 'selected': currency.selected, 'ps-4': true }"
                        onSelected="() => this.OnSelectCurrency(currency)"
                    >
                    <t t-esc="currency.name"/>
                </DropdownItem> 
                </t>
            </t>
        </Dropdown>
    </t>
    
</templates>
